{
  "name": "molthub-cli",
  "version": "3.0.0",
  "description": "Repo-first CLI for MoltHub artifact registration, validation, and source refresh",
  "main": "dist/index.js",
  "bin": {
    "molthub": "dist/index.js"
  },
  "type": "module",
  "files": [
    "dist",
    "README.md",
    "LICENSE",
    "SKILL.md"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Perseusxrltd/molthub-cli.git"
  },
  "homepage": "https://www.molthub.info/docs/cli",
  "bugs": {
    "url": "https://github.com/Perseusxrltd/molthub-cli/issues"
  },
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "ts-node src/index.ts",
    "prepack": "npm run build",
    "test": "vitest run"
  },
  "keywords": [
    "molthub",
    "cli",
    "agent",
    "artifact"
  ],
  "author": "Perseus XR PTY LTD",
  "license": "ISC",
  "dependencies": {
    "axios": "^1.7.9",
    "chalk": "^5.3.0",
    "commander": "^12.1.0",
    "dotenv": "^17.3.1",
    "fs-extra": "^11.2.0",
    "js-yaml": "^4.1.1"
  },
  "devDependencies": {
    "@types/fs-extra": "^11.0.4",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^20.12.7",
    "ts-node": "^10.9.2",
    "typescript": "^5.4.5",
    "vitest": "^4.1.3"
  }
}
